generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Subcontractor {
  id       String  @id
  name     String
  trade    String
  rate     Float
  color    String
  initials String

  lineItems    LineItem[]
  payrollItems PayrollItem[]
  payHistory   PayHistory[]
  workLines    WorkLine[]
}

model Invoice {
  id      String @id
  number  String @unique
  client  String
  address String
  issued  String
  due     String
  source  String

  lines LineItem[]
}

model LineItem {
  id        String  @id
  desc      String
  invoice   Float
  laborPct  Float
  expenses  Float   @default(0)
  status    String  @default("unassigned")
  note      String?

  invoiceId String
  inv       Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  subId String?
  sub   Subcontractor? @relation(fields: [subId], references: [id])

  payrollItems PayrollItem[]
}

model PayrollRun {
  id        String        @id @default(cuid())
  week      String
  createdAt DateTime      @default(now())
  items     PayrollItem[]
}

model PayrollItem {
  id     String @id @default(cuid())
  amount Float

  payrollRunId String
  run          PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)

  lineItemId String
  lineItem   LineItem @relation(fields: [lineItemId], references: [id])

  subId String
  sub   Subcontractor @relation(fields: [subId], references: [id])
}

model PayHistory {
  id     String @id @default(cuid())
  week   String
  amount Float
  items  Int

  subId String
  sub   Subcontractor @relation(fields: [subId], references: [id])
}

model ImportBatch {
  id               String   @id @default(cuid())
  sourceType       String   @default("csv")
  originalFileName String?
  uploadedByUserId String?
  totalRows        Int      @default(0)
  successfulRows   Int      @default(0)
  failedRows       Int      @default(0)
  status           String   @default("pending")
  errorSummary     String?
  createdAt        DateTime @default(now())

  invoices InvoiceRecord[]
  errors   ImportError[]
}

model ImportError {
  id            String  @id @default(cuid())
  importBatchId String
  rowNumber     Int
  fieldName     String?
  errorMessage  String
  rawValue      String?
  createdAt     DateTime @default(now())

  batch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
}

model InvoiceRecord {
  id                String   @id @default(cuid())
  invoiceNumber     String
  invoiceDate       String
  customerName      String
  customerEmail     String?
  customerPhone     String?
  customerAddress   String?
  serviceAddress    String?
  invoiceTotal      Float    @default(0)
  sourceType        String   @default("csv")
  externalInvoiceId String?
  invoiceStatus     String   @default("imported")
  importedByUserId  String?
  importBatchId     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  importBatch ImportBatch?      @relation(fields: [importBatchId], references: [id])
  lineItems   InvoiceLineItem[]
  workLines   WorkLine[]
}

model InvoiceLineItem {
  id            String   @id @default(cuid())
  invoiceId     String
  lineNumber    Int
  description   String
  quantity      Float?
  unitPrice     Float?
  lineTotal     Float
  notes         String?
  isWorkRelated Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoice   InvoiceRecord @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  workLines WorkLine[]
}

model WorkLine {
  id                String    @id @default(cuid())
  invoiceId         String
  invoiceLineItemId String
  title             String
  description       String?
  customerName      String
  serviceAddress    String?
  invoiceLineAmount Float
  assignedSubId     String?
  assignedAt        DateTime?
  dueDate           DateTime?
  workStatus        String    @default("unassigned")
  approvalStatus    String    @default("not_submitted")
  completionNotes   String?
  adminNotes        String?
  completedAt       DateTime?
  approvedAt        DateTime?
  approvedByUserId  String?
  payEligible       Boolean   @default(false)
  payAmount         Float?
  paySummaryId      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  invoice      InvoiceRecord   @relation(fields: [invoiceId], references: [id])
  lineItem     InvoiceLineItem @relation(fields: [invoiceLineItemId], references: [id])
  assignedSub  Subcontractor?  @relation(fields: [assignedSubId], references: [id])
}
